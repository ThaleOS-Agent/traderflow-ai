# ── TradeFlow AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# REQUIRED: AES-256 key for encrypting exchange API keys at rest in MongoDB.
# generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas, Railway addon, or local)
MONGODB_URI=mongodb://localhost:27017/tradeflow

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL your frontend is served from (used for CORS)
FRONTEND_URL=http://localhost:5173

# For the Vite frontend, tell it where the backend API lives
VITE_API_URL=/api

# ── Founder Account Provisioning (optional, manual script use only) ───────────
# These are NOT read automatically by the app. Use them only when running:
#   node backend/src/scripts/provisionFounderAccount.js
FOUNDER_EMAIL=
FOUNDER_PASSWORD=
FOUNDER_FIRST_NAME=Founder
FOUNDER_LAST_NAME=Account

# ── Exchange API Keys (optional — users can add their own via the UI) ─────────
# These are global defaults for the asset scanner; individual users set their own
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=true

OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# ── Notifications (optional) ──────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tradeflow.ai

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── MT4 / MT5 Broker Connector (optional) ────────────────────────────────────
# Option A: Local REST bridge EA running on your MetaTrader terminal
#   Deploy the companion EA that exposes a local HTTP server, then set:
MT5_API_URL=http://localhost:8080
MT5_API_KEY=

# Option B: MetaAPI cloud (https://metaapi.cloud — has a free tier)
MT5_METAAPI_TOKEN=
MT5_METAAPI_ACCOUNT_ID=

# ── ML / AI (optional) ────────────────────────────────────────────────────────
CLAUDE_API_KEY=
